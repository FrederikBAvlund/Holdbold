generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  TRAENER
  SPILLER
  SOME
  BOEDEKASSEFORMAND
}

enum MembershipStatus {
  PENDING
  ACTIVE
}

enum SignupStatus {
  IN
  OUT
  UNKNOWN
}

enum EventLogType {
  SIGNUP
  CANCEL
  REOPEN
}

enum EventSource {
  MANUAL
  SERIES
  ICAL
}

enum EventKind {
  TRAINING
  MATCH
}

enum EventMotmPollStatus {
  OPEN
  CLOSED
}

enum FineStatus {
  UNPAID
  PAID_PENDING
  PAID_APPROVED
  FORESLAET
  AFVIST
}

enum FineAutomationAction {
  MISSED_SIGNUP_AT_DEADLINE
  STATUS_CHANGE_AFTER_DEADLINE
  SAME_DAY_WITHDRAWAL
  MATCH_MOTM_WINNER
}

enum FineTemplateStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FineCategory {
  SOME
  FAELLES
  SPILLER
  DIVERSE
}
enum Recurrence {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum NotificationType {
  GENERAL
  EVENT
  FINE
  FINE_PROPOSED
  FINE_SYSTEM
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String?       @unique
  image        String?
  facebookId   String?       @unique
  passwordHash String?
  themePreset  String?
  themeConfig  Json?
  createdAt    DateTime      @default(now())
  accounts     Account[]
  sessions     Session[]
  memberships  Membership[]
  signups      Signup[]
  createdSeries EventSeries[]
  createdEvents Event[]      @relation("EventCreatedBy")
  canceledEvents Event[]     @relation("EventCanceledBy")
  eventsWithThingDuty Event[] @relation("EventThingCarrier")
  eventsWithBeerDuty Event[]  @relation("EventBeerCarrier")
  createdFineTemplates FineTemplate[]
  approvedFineTemplates FineTemplate[] @relation("FineTemplateApprover")
  rejectedFineTemplates FineTemplate[] @relation("FineTemplateRejecter")
  fines        Fine[]        @relation("FineRecipient")
  createdFines Fine[]        @relation("FineCreator")
  approvedFines Fine[]       @relation("FineApprover")
  markedPaidFines Fine[]     @relation("FineMarker")
  signupLogs      SignupLog[]
  notifications Notification[]
  eventLogs EventLog[] @relation("EventLogActor")
  createdFineCollections FineCollection[] @relation("FineCollectionCreator")
  pushSubscriptions PushSubscription[]
  eventMatchPlayerStats EventMatchPlayerStat[]
  createdEventMotmPolls EventMotmPoll[] @relation("EventMotmPollCreator")
  eventMotmBallots EventMotmBallot[] @relation("EventMotmBallotVoter")
  receivedEventMotmVotes EventMotmVote[] @relation("EventMotmVoteTarget")
  wonMatchMotmEvents Event[] @relation("EventMatchMotmWinner")
}

model Team {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  themePreset String        @default("atlantic")
  themeConfig Json?
  mobilePayBox String?
  createdAt   DateTime      @default(now())
  memberships Membership[]
  eventSeries EventSeries[]
  events      Event[]
  fineTemplates FineTemplate[]
  fineAutomationSettings FineAutomationSetting[]
  fineCollections FineCollection[]
  fines       Fine[]
  icalFeeds   IcalFeed[]
  notifications Notification[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      Role
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  team Team @relation(fields: [teamId], references: [id])

  @@unique([userId, teamId])
  @@index([teamId, role])
  @@index([teamId, status])
  @@index([userId, status])
}

model EventSeries {
  id                       String   @id @default(cuid())
  teamId                   String
  title                    String
  location                 String
  startDate                DateTime
  recurrence               Recurrence
  interval                 Int      @default(1)
  endDate                  DateTime?
  signupDeadlineHoursBefore Int      @default(24)
  kind                     EventKind @default(TRAINING)
  createdById              String
  createdAt                DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])
  createdBy User @relation(fields: [createdById], references: [id])
  events Event[]
}

model Event {
  id             String       @id @default(cuid())
  teamId         String
  seriesId       String?
  title          String
  date           DateTime
  location       String
  meetingTime    DateTime?
  signupDeadline DateTime
  source         EventSource  @default(MANUAL)
  externalUid    String?
  feedId         String?
  createdById    String?
  canceledAt     DateTime?
  canceledById   String?
  thingCarrierId String?
  beerCarrierId  String?
  kind           EventKind    @default(TRAINING)
  matchHomeGoals Int?
  matchAwayGoals Int?
  matchMotmUserId String?
  createdAt      DateTime     @default(now())

  team Team @relation(fields: [teamId], references: [id])
  series EventSeries? @relation(fields: [seriesId], references: [id])
  feed IcalFeed? @relation(fields: [feedId], references: [id])
  createdBy User? @relation("EventCreatedBy", fields: [createdById], references: [id])
  canceledBy User? @relation("EventCanceledBy", fields: [canceledById], references: [id])
  thingCarrier User? @relation("EventThingCarrier", fields: [thingCarrierId], references: [id])
  beerCarrier User? @relation("EventBeerCarrier", fields: [beerCarrierId], references: [id])
  matchMotmUser User? @relation("EventMatchMotmWinner", fields: [matchMotmUserId], references: [id])
  signups Signup[]
  fines Fine[]
  signupLogs SignupLog[]
  eventLogs EventLog[]
  matchPlayerStats EventMatchPlayerStat[]
  motmPolls EventMotmPoll[]

  @@index([teamId, date])
  @@index([teamId, kind, date])
  @@index([externalUid])
  @@index([canceledAt])
  @@index([thingCarrierId])
  @@index([beerCarrierId])
  @@index([matchMotmUserId])
}

model EventMotmPoll {
  id            String              @id @default(cuid())
  eventId       String              @unique
  createdById   String
  status        EventMotmPollStatus @default(OPEN)
  votesPerVoter Int
  revealCount   Int
  closedAt      DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  event      Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy  User               @relation("EventMotmPollCreator", fields: [createdById], references: [id], onDelete: Cascade)
  ballots    EventMotmBallot[]

  @@index([status])
}

model EventMotmBallot {
  id        String   @id @default(cuid())
  pollId     String
  voterId    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  poll   EventMotmPoll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  voter  User            @relation("EventMotmBallotVoter", fields: [voterId], references: [id], onDelete: Cascade)
  votes  EventMotmVote[]

  @@unique([pollId, voterId])
  @@index([pollId])
  @@index([voterId])
}

model EventMotmVote {
  id           String @id @default(cuid())
  ballotId      String
  targetUserId  String
  weight        Int    @default(1)

  ballot    EventMotmBallot @relation(fields: [ballotId], references: [id], onDelete: Cascade)
  targetUser User           @relation("EventMotmVoteTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([ballotId])
  @@index([targetUserId])
}

model EventMatchPlayerStat {
  id          String @id @default(cuid())
  eventId     String
  userId      String
  goals       Int    @default(0)
  assists     Int    @default(0)
  yellowCards Int    @default(0)
  redCards    Int    @default(0)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model EventLog {
  id        String       @id @default(cuid())
  eventId   String
  actorId   String?
  type      EventLogType @default(SIGNUP)
  message   String
  createdAt DateTime     @default(now())

  event Event @relation(fields: [eventId], references: [id])
  actor User? @relation("EventLogActor", fields: [actorId], references: [id])

  @@index([eventId, createdAt])
}

model Signup {
  id        String       @id @default(cuid())
  eventId   String
  userId    String
  status    SignupStatus @default(UNKNOWN)
  reason    String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  event Event @relation(fields: [eventId], references: [id])
  user User @relation(fields: [userId], references: [id])
  logs SignupLog[]

  @@unique([eventId, userId])
}

model SignupLog {
  id        String       @id @default(cuid())
  eventId   String
  userId    String
  status    SignupStatus
  reason    String?
  deadlineAt DateTime?
  createdAt DateTime     @default(now())

  signupId String
  signup   Signup @relation(fields: [signupId], references: [id])
  event Event @relation(fields: [eventId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([eventId, createdAt])
  @@index([userId, createdAt])
  @@index([signupId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  teamId    String?
  type      NotificationType @default(GENERAL)
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])
  team Team? @relation(fields: [teamId], references: [id])

  @@index([userId, readAt])
  @@index([teamId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Fine {
  id            String     @id @default(cuid())
  teamId        String
  userId        String
  eventId       String?
  templateId    String?
  amount        Int
  reason        String
  description   String?
  status        FineStatus @default(UNPAID)
  createdById   String?
  createdByLabel String?
  createdAt     DateTime   @default(now())
  markedPaidAt  DateTime?
  markedPaidById String?
  approvedAt    DateTime?
  approvedById  String?
  rejectedAt    DateTime?
  rejectedById  String?
  automationAction FineAutomationAction?

  team Team @relation(fields: [teamId], references: [id])
  user User @relation("FineRecipient", fields: [userId], references: [id])
  event Event? @relation(fields: [eventId], references: [id])
  template FineTemplate? @relation(fields: [templateId], references: [id])
  createdBy User? @relation("FineCreator", fields: [createdById], references: [id])
  markedPaidBy User? @relation("FineMarker", fields: [markedPaidById], references: [id])
  approvedBy User? @relation("FineApprover", fields: [approvedById], references: [id])

  @@index([teamId, status])
  @@index([userId, status])
}

model FineTemplate {
  id          String   @id @default(cuid())
  teamId      String
  title       String
  amount      Int
  category    FineCategory @default(DIVERSE)
  description String?
  createdById String?
  status      FineTemplateStatus @default(APPROVED)
  approvedAt  DateTime?
  approvedById String?
  rejectedAt  DateTime?
  rejectedById String?
  createdAt   DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])
  createdBy User? @relation(fields: [createdById], references: [id])
  approvedBy User? @relation("FineTemplateApprover", fields: [approvedById], references: [id])
  rejectedBy User? @relation("FineTemplateRejecter", fields: [rejectedById], references: [id])
  fines Fine[]
  fineCollections FineCollection[]
  fineAutomationTrainingTemplates FineAutomationSetting[] @relation("FineAutomationTemplateTraining")
  fineAutomationMatchTemplates FineAutomationSetting[] @relation("FineAutomationTemplateMatch")

  @@index([teamId])
  @@index([teamId, status])
  @@index([teamId, category])
}

model FineAutomationSetting {
  id                   String               @id @default(cuid())
  teamId               String
  action               FineAutomationAction
  appliesTraining      Boolean              @default(false)
  appliesMatch         Boolean              @default(false)
  templateTrainingId   String?
  templateMatchId      String?
  excludedRoles        Role[]               @default([SOME])
  isActive             Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  team               Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  templateTraining   FineTemplate? @relation("FineAutomationTemplateTraining", fields: [templateTrainingId], references: [id], onDelete: Restrict)
  templateMatch      FineTemplate? @relation("FineAutomationTemplateMatch", fields: [templateMatchId], references: [id], onDelete: Restrict)

  @@unique([teamId, action])
  @@index([teamId, action])
}

model FineCollection {
  id           String   @id @default(cuid())
  teamId       String
  templateId   String
  deadlineAt   DateTime
  intervalHours Int     @default(24)
  lastRunAt    DateTime?
  isActive     Boolean  @default(true)
  createdById  String
  createdAt    DateTime @default(now())

  team      Team        @relation(fields: [teamId], references: [id])
  template  FineTemplate @relation(fields: [templateId], references: [id])
  createdBy User        @relation("FineCollectionCreator", fields: [createdById], references: [id])

  @@index([teamId, isActive])
  @@index([deadlineAt])
}

model IcalFeed {
  id             String   @id @default(cuid())
  teamId         String
  name           String
  url            String
  lastImportedAt DateTime?
  createdAt      DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])
  events Event[]

  @@index([teamId])
  @@unique([teamId, url])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
